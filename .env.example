# Variables d'environnement pour les serveurs MCP (.mcp.json)
# NE PAS COMMITER — contient des secrets.

# Clé API du workspace Somcraft (serveur MCP "somcraft")
# Format attendu : sk_agent_...
SOMCRAFT_MCP_API_KEY=

# Clé API ServiceDesk (serveur MCP "servicedesk", header Authorization: Bearer)
SOMTECH_DESK_API_KEY=
