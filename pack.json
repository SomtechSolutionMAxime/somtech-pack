{
  "name": "somtech-pack",
  "version": "1.0.0",
  "description": "Pack de configuration réutilisable pour projets Somtech (Claude Code, features, plugins Cowork, scripts)",
  "author": "Somtech",
  "repository": "https://github.com/SomtechSolutionMAxime/somtech-pack.git",
  "modules": {
    "core": {
      "description": "Config Claude Code (skills/agents/commands/hooks) + scripts + docs + sécurité",
      "default": true,
      "paths": [
        ".claude/",
        "scripts/",
        "docs/",
        "security/"
      ]
    },
    "features": {
      "description": "Blueprints de features réutilisables",
      "default": true,
      "paths": [
        "features/"
      ]
    },
    "mockmig": {
      "description": "Workflow migration maquette → production",
      "default": false,
      "paths": [
        ".mockmig/",
        ".specify/"
      ]
    },
    "plugins": {
      "description": "Plugins Cowork (audit-loi25, somtech-proposals, somtech-silo-manager, somtech-somcraft-deployer)",
      "default": false,
      "paths": [
        "plugins/"
      ]
    }
  }
}
